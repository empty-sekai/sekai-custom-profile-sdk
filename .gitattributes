# Normalize all text files to LF on commit; checkout in the working tree's
# native ending. Avoids spurious CRLF↔LF diffs when contributors edit on
# different platforms.
* text=auto eol=lf

# Source code — keep LF in working tree too (avoids surprises with shell
# scripts and tools that don't tolerate CRLF).
*.rs        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.Dockerfile text eol=lf
Dockerfile  text eol=lf

# Binary — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.wasm      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.zip       binary
*.tar       binary
*.gz        binary
*.xz        binary

# Windows-only files that should keep CRLF if any are ever added.
*.bat       text eol=crlf
*.cmd       text eol=crlf
